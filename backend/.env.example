# Required
JWT_SECRET=change_this_to_a_random_secret_string
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/earthonline

# Discord OAuth
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

# Discord Bot
DISCORD_BOT_TOKEN=your_discord_bot_token

# Optional
BACKEND_URL=https://earthonline.onrender.com
FRONTEND_URL=https://earthonline1.pages.dev
DISCORD_REDIRECT_URI=http://localhost:3001/api/auth/discord/callback
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://earthonline1.pages.dev,https://earthonline.onrender.com
ADMIN_DISCORD_IDS=comma,separated,discord,user,ids
DISCORD_WEBHOOK_URL=
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
NODE_ENV=development
PORT=3001
